 document.getElementById('searchInput').addEventListener('input',
function(e) {
 const query = e.target.value.toLowerCase();
 if (query === '') {
 currentPosts = [...postsData];
 } else {
 currentPosts = postsData.filter(post =>
 post.title.toLowerCase().includes(query) ||
 post.author.toLowerCase().includes(query) ||
 post.description.toLowerCase().includes(query)
 );
 }
 renderPosts(currentPosts);
 });
 // Mobile navigation
 document.querySelectorAll('.nav-item').forEach(item => {
 item.addEventListener('click', function() {
 document.querySelectorAll('.nav-item').forEach(i => {
 i.classList.remove('text-[#ff2442]');
 i.classList.add('text-gray-400');
 });
 this.classList.remove('text-gray-400');
 this.classList.add('text-[#ff2442]');
 });
 });
 // Close modal on outside click
 document.getElementById('postModal').addEventListener('click',
function(e) {
 if (e.target === this) {
 closeModal();
 }
 });
 // Infinite scroll simulation
 window.addEventListener('scroll', () => {
 if (isLoading) return;

 const { scrollTop, scrollHeight, clientHeight } =
document.documentElement;
 if (scrollTop + clientHeight >= scrollHeight - 100) {
 isLoading = true;
 document.getElementById('loadingSpinner').style.display =
'flex';

 setTimeout(() => {
 // Duplicate existing posts with new IDs for infinite
scroll effect
 const newPosts = postsData.map(post => ({
 ...post,
id: post.id + currentPosts.length,
 likes: Math.floor(Math.random() * 5000) + 100,
 isLiked: false
 }));
 currentPosts = [...currentPosts, ...newPosts];
 renderPosts(currentPosts);
 isLoading = false;
 document.getElementById('loadingSpinner').style.display =
'none';
 }, 1000);
 }
 });
 // Initial render
 renderPosts(currentPosts);
 document.getElementById('loadingSpinner').style.display = 'none';
 </script>
</body>
</html>
